{
  "name": "devflow",
  "version": "0.2.5",
  "description": "DevFlow - a workflow-as-plugin CLI orchestrator that runs a full spec-driven development pipeline (Intent -> SpecKit -> BMAD -> Coding -> Tests -> Security -> PR) and exposes it as slash commands for Cursor, Claude Code and GitHub Copilot.",
  "type": "module",
  "bin": {
    "devflow": "./dist/cli.js"
  },
  "files": [
    "dist",
    "commands",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "devflow",
    "workflow",
    "orchestrator",
    "spec-driven-development",
    "cursor",
    "claude",
    "copilot",
    "plugin",
    "ai-agents"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
